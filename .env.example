# ──────────────────────────────────────────
# Zahauton Search Engine — Environment
# ──────────────────────────────────────────

# PostgreSQL
POSTGRES_PASSWORD=zahauton_secret
DATABASE_URL=postgresql://postgres:zahauton_secret@localhost:5432/zahauton

# Dragonfly (Redis-compatible)
DRAGONFLY_URL=localhost:6379
DRAGONFLY_PASSWORD=

# Typesense
TYPESENSE_API_KEY=zahauton_ts_key
TYPESENSE_URL=http://localhost:8108

# API
PORT=8080
CORS_ORIGINS=*

# Frontend
VITE_API_URL=http://localhost:8080/api
